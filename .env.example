# ---------------------------------------------------------------------------
# ForexTestLab environment variables
# Copy this file to `.env.local` and fill in real values for local development.
# On Vercel, set these in Project Settings -> Environment Variables.
# NEVER commit real secrets. `.env.local` is git-ignored.
# ---------------------------------------------------------------------------

# Public site URL (used for canonical URLs, sitemap, Open Graph, etc.)
# NEXT_PUBLIC_ variables are exposed to the browser — put NON-secret values here only.
NEXT_PUBLIC_SITE_URL=https://forextestlab.com

# ---------------------------------------------------------------------------
# Waitlist / contact storage provider
# The default ("local") writes submissions to JSON files under /data in dev.
# Swap this for a real provider once you wire one up (see README).
# ---------------------------------------------------------------------------
STORAGE_PROVIDER=local

# ---------------------------------------------------------------------------
# Supabase (optional — for persisting waitlist/contact submissions)
# Get these from https://app.supabase.com -> Project Settings -> API
# SUPABASE_SERVICE_ROLE_KEY is a SECRET — server-side only, never expose it.
# ---------------------------------------------------------------------------
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Resend (optional — transactional email / notifications)
# https://resend.com/api-keys
# ---------------------------------------------------------------------------
# RESEND_API_KEY=
# CONTACT_NOTIFICATION_TO=hello@forextestlab.com

# ---------------------------------------------------------------------------
# Mailchimp (optional — email marketing lists)
# ---------------------------------------------------------------------------
# MAILCHIMP_API_KEY=
# MAILCHIMP_AUDIENCE_ID=
# MAILCHIMP_SERVER_PREFIX=us1

# ---------------------------------------------------------------------------
# ConvertKit (optional — email marketing lists)
# ---------------------------------------------------------------------------
# CONVERTKIT_API_KEY=
# CONVERTKIT_FORM_ID=

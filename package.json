{
  "name": "forextestlab",
  "version": "1.0.0",
  "private": true,
  "description": "ForexTestLab forex backtesting and historical market-replay platform.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "data:import": "tsx scripts/import-market-data.ts",
    "paddle:seed": "tsx scripts/seed-paddle-catalog.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1089.0",
    "@paddle/paddle-js": "^1.6.4",
    "@paddle/paddle-node-sdk": "3.7.0",
    "@prisma/client": "^5.22.0",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.6",
    "decimal.js": "^10.6.0",
    "hyparquet": "^1.26.2",
    "hyparquet-compressors": "^1.1.1",
    "lightweight-charts": "^4.2.3",
    "lucide-react": "^0.454.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.19",
    "dotenv": "^16.6.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.4.38",
    "prisma": "^5.22.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.23.1",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  }

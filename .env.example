# ---------------------------------------------------------------------------
# ForexTestLab environment variables
# Copy this file to `.env.local` (Next.js) / `.env` (Prisma CLI + scripts) and
# fill in real values. NEVER commit real secrets — `.env*` is git-ignored.
# Only NEXT_PUBLIC_* variables are exposed to the browser; keep all keys/tokens
# WITHOUT that prefix so they stay server-side.
# ---------------------------------------------------------------------------

# --- Database -------------------------------------------------------------
# Prisma is configured for PostgreSQL. With Supabase, use the pooled URL for
# application traffic and the direct/session URL for schema operations.
DATABASE_URL="postgresql://user:password@pooler-host:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://user:password@pooler-host:5432/postgres"

# --- Public site ----------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://forextestlab.com

# --- Supabase Auth --------------------------------------------------------
# Find these in Supabase -> Project Settings -> API / Connect.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only key used for account deletion. Never expose it with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=

# --- Market-data provider -------------------------------------------------
# r2 (production) | local_database | local_csv | demo
MARKET_DATA_PROVIDER=r2
# Production should not silently substitute synthetic prices when stored data is missing.
ENABLE_DEMO_DATA=false

# Cloudflare R2 (server-only; never expose these with a NEXT_PUBLIC_ prefix)
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET_NAME=YOUR_BUCKET_NAME
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
R2_PREFIX=market_data

# --- Optional external providers (DISABLED by default) --------------------
# ⚠️ Free API access does NOT automatically include public-display,
# redistribution, or commercial-use rights. Before enabling any external
# provider on the public platform, review the provider's current terms and
# obtain any required written permission or commercial licence.
TWELVE_DATA_ENABLED=false
TWELVE_DATA_API_KEY=

TRADERMADE_ENABLED=false
TRADERMADE_API_KEY=

# Manual, owner-authorised import of lawfully-downloaded files only. No
# automatic download or scraping is performed. Not an authorised partner.
DUKASCOPY_DATA_AUTHORIZED=false

# --- Admin --------------------------------------------------------------
# Bearer token required for any administrative data-import endpoint.
ADMIN_IMPORT_TOKEN=

# --- Simulation defaults --------------------------------------------------
DEFAULT_ACCOUNT_BALANCE=10000
DEFAULT_SPREAD_PIPS=1.0
DEFAULT_COMMISSION_PER_LOT=0
DEFAULT_SLIPPAGE_PIPS=0

# --- Paddle billing -------------------------------------------------------
# Start with sandbox. Switch PADDLE_MODE to live only after the full sandbox
# checkout and webhook flow passes and the live domain is approved in Paddle.
PADDLE_MODE=sandbox
NEXT_PUBLIC_PADDLE_ENV=sandbox

# Server-only API keys. Never expose these with a NEXT_PUBLIC_ prefix.
PADDLE_SANDBOX_API_KEY=
PADDLE_LIVE_API_KEY=

# Paddle.js client-side tokens (safe for checkout initialization).
PADDLE_SANDBOX_CLIENT_TOKEN=
PADDLE_LIVE_CLIENT_TOKEN=

# Endpoint secrets for POST /api/paddle/webhook.
PADDLE_SANDBOX_WEBHOOK_SECRET=
PADDLE_LIVE_WEBHOOK_SECRET=

# Six recurring price IDs created in the corresponding Paddle catalog (pri_...).
PADDLE_SANDBOX_STARTER_MONTH_PRICE_ID=
PADDLE_SANDBOX_STARTER_YEAR_PRICE_ID=
PADDLE_SANDBOX_PRO_MONTH_PRICE_ID=
PADDLE_SANDBOX_PRO_YEAR_PRICE_ID=
PADDLE_SANDBOX_ADVANCED_MONTH_PRICE_ID=
PADDLE_SANDBOX_ADVANCED_YEAR_PRICE_ID=
PADDLE_LIVE_STARTER_MONTH_PRICE_ID=
PADDLE_LIVE_STARTER_YEAR_PRICE_ID=
PADDLE_LIVE_PRO_MONTH_PRICE_ID=
PADDLE_LIVE_PRO_YEAR_PRICE_ID=
PADDLE_LIVE_ADVANCED_MONTH_PRICE_ID=
PADDLE_LIVE_ADVANCED_YEAR_PRICE_ID=

# Catalog seed inputs in USD cents. Set every value before `npm run paddle:seed`.
PADDLE_STARTER_MONTH_PRICE_USD_CENTS=
PADDLE_STARTER_YEAR_PRICE_USD_CENTS=
PADDLE_PRO_MONTH_PRICE_USD_CENTS=1000
PADDLE_PRO_YEAR_PRICE_USD_CENTS=8000
PADDLE_ADVANCED_MONTH_PRICE_USD_CENTS=
PADDLE_ADVANCED_YEAR_PRICE_USD_CENTS=
